// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
}

enum QuestionFrequency {
  High
  Medium
  Low
}

enum FrontendFramework {
  react
  vue
  nextjs
}

enum ArticleDifficulty {
  Beginner
  Intermediate
  Advanced
}

model Question {
  id              String            @id
  category        String
  examCode        String
  number          Int
  title           String
  description     String
  tagId           String
  dateLabel       String
  publishedAt     DateTime
  frequency       QuestionFrequency
  tags            String[]
  scenarioEnglish String
  scenarioKorean  String
  requirements    Json
  choices         Json
  answerId        String
  serviceMain     Json
  serviceOthers   Json
  insight         String
  deepDiveTable   Json
  cheatSheet      Json
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([category, publishedAt(sort: Desc)])
  @@index([examCode, number(sort: Desc)])
  @@unique([category, number])
}

model FrontendArticle {
  id              String             @id
  category        String             @default("frontend")
  framework       FrontendFramework
  title           String
  description     String
  summary         String
  publishedAt     DateTime
  readTimeMinutes Int                @default(8)
  difficulty      ArticleDifficulty  @default(Beginner)
  tags            String[]
  sections        Json
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([framework, publishedAt(sort: Desc)])
  @@index([category, publishedAt(sort: Desc)])
}

